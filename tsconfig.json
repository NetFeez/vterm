{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "declaration": true,
    "esModuleInterop": true,
    "sourceMap": true,
    "strict": true,
    "strictNullChecks": true,
    "rootDir": "src",
    "outDir": "build",
    "types": [ "node" ]
  },
  "include": [ "src/**/*" ]
}
